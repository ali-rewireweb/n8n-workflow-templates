    {
      "parameters": {
        "jsCode": "const prev = $('Build Download URL1').first().json;\nconst tikaItem = $input.first();\nconst MAX_CHARS = 8000;\n\nlet text = '';\nconst j = tikaItem.json;\nif (typeof j === 'string') text = j;\nelse if (j && typeof j.data === 'string') text = j.data;\nelse if (j && typeof j.body === 'string') text = j.body;\nelse if (j && typeof j.text === 'string') text = j.text;\nelse if (j) {\n  for (const val of Object.values(j)) {\n    if (typeof val === 'string' && val.length > 10) { text = val; break; }\n  }\n}\n\ntext = text.replace(/\\s+/g, ' ').trim();\nif (text.length > MAX_CHARS) text = text.substring(0, MAX_CHARS);\n\nfunction simpleHash(str) {\n  let hash = 0;\n  for (let i = 0; i < str.length; i++) {\n    const char = str.charCodeAt(i);\n    hash = ((hash << 5) - hash) + char;\n    hash = hash & hash;\n  }\n  return Math.abs(hash).toString(16);\n}\n\nreturn [{\n  json: {\n    source_doc_id: prev.source_doc_id,\n    user_id: prev.user_id,\n    filename: prev.filename,\n    extracted_text: text,\n    checksum: simpleHash(text),\n    text_length: text.length\n  }\n}];"
      },
      "id": "81256393-9715-4704-9c29-b7ef7393484e",
      "name": "Prepare Text1",
