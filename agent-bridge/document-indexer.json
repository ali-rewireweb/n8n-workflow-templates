      "parameters": {
        "jsCode": "const STORAGE_BASE = 'https://ai-rooster.nl/storage/';\nconst item = $input.first().json;\n\nreturn [{\n  json: {\n    source_doc_id: item.id,\n    doc_name: item.doc_name,\n    filename: item.original_name || item.doc_name,\n    url: STORAGE_BASE + item.file_path,\n    user_id: 1\n  }\n}];"
      },
