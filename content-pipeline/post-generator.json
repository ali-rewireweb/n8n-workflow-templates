    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"posts\": {\n      \"type\": \"array\",\n      \"minItems\": 3,\n      \"maxItems\": 3,\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"post_index\": {\n            \"type\": \"integer\",\n            \"minimum\": 1,\n            \"maximum\": 3,\n            \"description\": \"Post number 1, 2, or 3\"\n          },\n          \"angle\": {\n            \"type\": \"string\",\n            \"description\": \"Short label like 'pain-point hook', 'tactical tip', 'contrarian take'\"\n          },\n          \"post_copy\": {\n            \"type\": \"string\",\n            \"description\": \"Full Facebook post text, 250 to 500 characters. No em dashes. No banned phrases.\"\n          },\n          \"hashtags\": {\n            \"type\": \"array\",\n            \"items\": { \"type\": \"string\" },\n            \"description\": \"3 to 5 relevant hashtags without the # symbol\"\n          },\n          \"image_prompt\": {\n            \"type\": \"string\",\n            \"description\": \"Detailed image generation prompt. Specify style (photorealistic or flat or isometric), color palette, and mood. No text in image. No cliches.\"\n          }\n        },\n        \"required\": [\"post_index\", \"angle\", \"post_copy\", \"image_prompt\", \"hashtags\"]\n      }\n    }\n  },\n  \"required\": [\"posts\"]\n}"
      },
