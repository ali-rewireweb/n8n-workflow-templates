    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const update = $input.item.json;\nconst cb = update.callback_query;\nif (!cb) throw new Error('Not a callback_query. Got: ' + JSON.stringify(Object.keys(update)));\n\nconst data = cb.data || '';\nconst sep = data.indexOf('_');\nif (sep === -1) throw new Error('Invalid callback format: ' + data);\n\nconst action = data.substring(0, sep);\nconst postId = Number(data.substring(sep + 1));\nif (!action || !postId) throw new Error('Could not parse from: ' + data);\n\nconst chatId = cb.message && cb.message.chat ? String(cb.message.chat.id) : '-1003876909621';\n\nreturn { json: { action, post_id: postId, callback_query_id: cb.id, chat_id: chatId } };"
      },
      "id": "bbe00cb5-bbef-42c4-95ec-8f76fa960a0c",
      "name": "Parse Callback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2176,
        0
      ]
    },
    {
      "parameters": {
        "url": "=https://YOUR_PROJECT_REF.supabase.co/rest/v1/facebook_posts?id=eq.{{ $json.post_id }}&select=id,post_copy,image_url,article_id",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "YOUR_SUPABASE_KEY"
            },
