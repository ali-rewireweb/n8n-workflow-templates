        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"openai/text-embedding-3-small\",\n  \"input\": {{ JSON.stringify($json.extracted_text) }}\n}",
        "options": {}
      },
      "id": "1736b9fe-88e7-44ef-b142-5e5c7cef37e8",
      "name": "Generate Embedding1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        160,
        768
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const embeddingResp = $input.first().json;\nconst prev = $('Prepare Text1').first().json;\n\nconst embedding = embeddingResp?.data?.[0]?.embedding;\nif (!embedding || !Array.isArray(embedding)) {\n  throw new Error('No embedding returned for doc ' + prev.source_doc_id + '. Response: ' + JSON.stringify(embeddingResp));\n}\n\nconst safeFilename = prev.filename.replace(/'/g, \"''\");\nconst safeText = prev.extracted_text.replace(/\\$dmtag\\$/g, '$dm tag$');\nconst vectorLiteral = '[' + embedding.join(',') + ']';\n\nconst query = [\n  'INSERT INTO document_index',\n  '(source_doc_id, user_id, filename, extracted_text, embedding, indexed_at, checksum)',\n  'VALUES (',\n  `  ${parseInt(prev.source_doc_id)},`,\n  `  ${parseInt(prev.user_id)},`,\n  `  '${safeFilename}',`,\n  `  $dmtag$${safeText}$dmtag$,`,\n  `  '${vectorLiteral}'::vector,`,\n  '  NOW(),',\n  `  '${prev.checksum}'`,\n  ')',\n  'ON CONFLICT (source_doc_id) DO UPDATE SET',\n  '  extracted_text = EXCLUDED.extracted_text,',\n  '  embedding      = EXCLUDED.embedding,',\n  '  indexed_at     = NOW(),',\n  '  checksum       = EXCLUDED.checksum'\n].join('\\n');\n\nreturn [{ json: { query, source_doc_id: prev.source_doc_id, filename: prev.filename } }];"
      },
