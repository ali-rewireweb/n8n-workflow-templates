      "parameters": {
        "jsCode": "// postgres_ids: every source_doc_id currently in the index\n// $input.all(): every currently active doc in MySQL\n// orphans = IDs that are indexed but no longer exist in MySQL\n\nconst postgresIds = $('Collect Postgres IDs').first().json.postgres_ids;\n\nconst mysqlIds = new Set(\n  $input.all()\n    .map(i => parseInt(i.json.id))\n    .filter(id => !isNaN(id))\n);\n\nconst orphans = postgresIds.filter(id => !mysqlIds.has(id));\n\nreturn [{ json: { orphans, count: orphans.length } }];"
      },
