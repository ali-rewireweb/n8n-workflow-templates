      "id": "ef4862c2-c1ab-4f6d-a452-0c4e9ab08d0b",
      "name": "Extract Text (Tika)1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -512,
        912
      ],
      "continueOnFail": true
