    {
      "parameters": {
        "jsCode": "const articleId = $('Get Next Article').first().json.id;\nconst items = $input.all();\n\nreturn items.map(item => {\n  // Split Out with a dotted path puts the data under a literal \"output.posts\" key.\n  // Fall back to other shapes just in case.\n  const post = item.json[\"output.posts\"]\n            || item.json.output?.posts\n            || item.json;\n\n  const hashtagLine = (post.hashtags && post.hashtags.length)\n    ? '\\n\\n' + post.hashtags.map(h => '#' + h).join(' ')\n    : '';\n\n  const filename = `article-${articleId}-post-${post.post_index}-${Date.now()}.png`;\n\n  return {\n    json: {\n      article_id: articleId,\n      post_index: post.post_index,\n      angle: post.angle,\n      post_copy: (post.post_copy || '') + hashtagLine,\n      image_prompt: post.image_prompt,\n      image_filename: filename\n    }\n  };\n});"
      },
