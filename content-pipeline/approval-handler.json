    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const cb = $('Parse Callback').item.json;\nconst raw = $input.item.json;\nconst post = Array.isArray(raw) ? raw[0] : raw;\nif (!post || !post.id) throw new Error('Post not found for id: ' + cb.post_id);\nreturn { json: { action: cb.action, post_id: post.id, post_copy: post.post_copy, image_url: post.image_url, callback_query_id: cb.callback_query_id, chat_id: cb.chat_id } };"
      },
      "id": "06006294-f69c-4573-9d68-9274f75c2a38",
      "name": "Merge Data",
